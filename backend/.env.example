# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sachyojana"

# Redis
REDIS_URL="redis://localhost:6379"

# Google Gemini AI
GEMINI_API_KEY="your_gemini_api_key_here"

# Government Data APIs
DATA_GOV_IN_API_KEY="your_data_gov_in_api_key_here"
APISETU_API_KEY="your_apisetu_api_key_here"

# Admin Panel
ADMIN_API_KEY="your_secure_admin_api_key_here"

# Server
PORT=3001
NODE_ENV=development

# File Uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# File Retention (hours)
FILE_RETENTION_HOURS=48
